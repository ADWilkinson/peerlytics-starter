{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2022", "DOM"],
    "jsx": "react-jsx",
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "types": ["node"]
  },
  "include": ["peerlytics/**/*.ts", "usdctofiat/**/*.ts", "usdctofiat/**/*.tsx"],
  "exclude": ["demo", "node_modules", "**/node_modules", "**/dist"]
}
